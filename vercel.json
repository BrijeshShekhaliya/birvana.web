{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets/|downloads/|releases\\.json|favicon\\.svg|icons\\.svg|robots\\.txt|sitemap\\.xml).*)",
      "destination": "/index.html"
    }
  ]
}
