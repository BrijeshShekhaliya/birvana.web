{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/((?!api/).*)",
      "has": [
        {
          "type": "host",
          "value": "birvana.vercel.app"
        }
      ],
      "destination": "https://birvana.indevs.in/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets/|downloads/|releases\\.json|favicon\\.svg|icons\\.svg|robots\\.txt|sitemap\\.xml).*)",
      "destination": "/index.html"
    }
  ]
}
